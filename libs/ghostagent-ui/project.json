{
  "name": "ghostagent-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ghostagent-ui/src",
  "prefix": "gf",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/ghostagent-ui/src/**/*.ts",
          "libs/ghostagent-ui/src/**/*.html"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/ghostagent-ui"],
      "options": {
        "jestConfig": "libs/ghostagent-ui/jest.config.ts",
        "tsConfig": "libs/ghostagent-ui/tsconfig.spec.json"
      }
    }
  }
}
